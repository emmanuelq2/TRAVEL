# ── API Keys ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
DEEPGRAM_API_KEY=...
ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=...

# Required for pyannote diarization models (accept model license on HF first)
# https://huggingface.co/pyannote/speaker-diarization-3.1
# https://huggingface.co/pyannote/segmentation-3.0
HUGGINGFACE_TOKEN=hf_...

# ── ASR Routing ───────────────────────────────────────────────────────────────
ASR_BATCH_PROVIDER=cohere           # batch: cohere | whisper
ASR_STREAM_PROVIDER=deepgram        # realtime: deepgram | whisper
ASR_FALLBACK_PROVIDER=whisper
ASR_FALLBACK_ENABLED=true

# ── Cohere Transcribe ─────────────────────────────────────────────────────────
COHERE_TRANSCRIBE_MODEL=cohere-transcribe-03-2026

# ── Deepgram ──────────────────────────────────────────────────────────────────
DEEPGRAM_MODEL=nova-3
DEEPGRAM_HOTWORDS_ENABLED=true

# ── Whisper (fallback) ────────────────────────────────────────────────────────
WHISPER_MODEL=whisper-1

# ── VAD (Silero) ──────────────────────────────────────────────────────────────
VAD_THRESHOLD=0.5
VAD_MIN_SPEECH_MS=250
VAD_MIN_SILENCE_MS=500

# ── Diarization ───────────────────────────────────────────────────────────────
DIARIZATION_ENABLED=true
MAX_SPEAKERS=4

# ── Claude Dialogue Manager ───────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1024
